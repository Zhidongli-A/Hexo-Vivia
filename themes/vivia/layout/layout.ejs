<!DOCTYPE html>
<%
  let hasBanner;
  if (theme.banner.enable && (is_home() || theme.banner.onAllPages)) {
    if (is_post() && page.photos && page.photos.length)
      hasBanner = "desktop";
    else
      hasBanner = "true"
  } else {
    hasBanner = "false";
  }
%>
<html theme="dark" showBanner="<%- theme.banner.enable ? 'true' : 'false' %>" hasBanner="<%- hasBanner %>">
<link href="https://cdn.staticfile.org/font-awesome/6.4.2/css/fontawesome.min.css" rel="stylesheet">
<link href="https://cdn.staticfile.org/font-awesome/6.4.2/css/brands.min.css" rel="stylesheet">
<link href="https://cdn.staticfile.org/font-awesome/6.4.2/css/solid.min.css" rel="stylesheet">
<script src="<%- url_for("/js/color.global.min.js") %>" ></script>
<script src="<%- url_for("/js/load-settings.js") %>" ></script>
<%- partial('_partial/head') %>

<style>
  /* ── 背景容器 ── */
  #bg-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -2; background-size: cover; background-position: center; background-repeat: no-repeat; }
  #bg-dim { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; background: rgba(0,0,0,0.55); backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px); }

  /* ── 加载动画 ── */
  #loading-screen {
    position: fixed;
    top: 0; left: 0;
    width: 100vw; height: 100vh;
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #0d0d12;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }
  #loading-screen.hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* 加载卡片 — 宽度由内容决定 */
  .loading-card {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
    max-width: 90vw;
  }

  /* 头部：头像 + 文字 */
  .loading-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .loading-avatar {
    width: 56px;
    height: 56px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .loading-texts {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .loading-title {
    font-size: 20px;
    color: #ffffff;
    line-height: 1.4;
    white-space: nowrap;
  }
  .loading-subtitle {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.4;
    white-space: nowrap;
  }

  /* Windows 风格 indeterminate 加载条 */
  .loading-track {
    width: 100%;
    height: 5px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    overflow: hidden;
  }
  .loading-thumb {
    width: 35%;
    height: 100%;
    background: #4a8eff;
    border-radius: 3px;
    animation: windows-indeterminate 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }
  @keyframes windows-indeterminate {
    0%   { transform: translateX(-100%); }
    50%  { transform: translateX(400%); }
    100% { transform: translateX(-100%); }
  }

  /* 错误提示（默认隐藏） */
  .loading-error {
    display: none;
    width: 100%;
    padding: 10px 16px;
    background: rgba(255, 140, 155, 0.12);
    border: 1px solid rgba(255, 140, 155, 0.25);
    border-radius: 8px;
    color: #ffb7c5;
    font-size: 16px;
    line-height: 1.5;
    text-align: center;
    box-sizing: border-box;
  }

  /* 出错时：隐藏加载条，显示错误 */
  #loading-screen.error .loading-track {
    display: none;
  }
  #loading-screen.error .loading-error {
    display: block;
  }

  /* ── 入场动画（背景加载后触发） ── */
  .entrance-el {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .bg-loaded .entrance-el {
    opacity: 1;
    transform: translateY(0);
  }
  #nav            { transition-delay: 0.05s; }
  #sidebar-wrapper { transition-delay: 0.20s; }
  #content-body   { transition-delay: 0.35s; }
  #footer-wrapper { transition-delay: 0.50s; }
</style>

<body>
  <!-- 加载屏幕 -->
  <div id="loading-screen">
    <div class="loading-card">
      <div class="loading-header">
        <img class="loading-avatar" src="<%- url_for(theme.avatar) %>" alt="avatar" onerror="this.style.display='none'">
        <div class="loading-texts">
          <div class="loading-title">枝动力の小站</div>
          <div class="loading-subtitle">资源正在加载呢~</div>
        </div>
      </div>
      <div class="loading-track"><div class="loading-thumb"></div></div>
      <div class="loading-error">不好意思!出现了意外~</div>
    </div>
  </div>

  <!-- 背景 -->
  <div id="bg-overlay"></div>
  <div id="bg-dim"></div>

  <script>
  // 等背景图完全加载 → 隐藏加载屏 + 入场动画
  (function() {
    var html = document.documentElement;
    var cacheBuster = Date.now();
    var bgUrl = 'https://api.elaina.cat/random/?' + cacheBuster;
    var img = new Image();
    var loading = document.getElementById('loading-screen');

    // 加载中禁止浏览器滚动条
    html.style.overflow = 'hidden';

    function showContent() {
      html.classList.add('bg-loaded');
      loading.classList.add('hide');
      // 恢复滚动
      html.style.overflow = '';
    }

    img.onload = function() {
      // 同一 URL 预加载完成，设为背景（浏览器直接用缓存）
      document.getElementById('bg-overlay').style.backgroundImage = 'url(' + bgUrl + ')';
      // 双 rAF 确保浏览器已绘制背景再展示内容
      requestAnimationFrame(function() {
        requestAnimationFrame(showContent);
      });
    };
    img.onerror = function() {
      document.getElementById('bg-overlay').style.background = '#1a1a2e';
      // 显示错误状态：隐藏加载条，显示错误提示，停留在此页面直到用户刷新
      loading.classList.add('error');
    };
    img.src = bgUrl;
  })();
  </script>

  <script>document.documentElement.classList.add('js');</script>

  <% if (theme.previewMode) { %>
    <%- partial('_widget/color') %>
  <% } %>
  <% if (hasBanner != "false" && theme.banner.enable) { %>
    <%- partial('_partial/banner') %>
  <% } %>

  <div id="main-grid" class="<% if (theme.sidebar.position == "right") { %> right-sidebar <% } %>">
    <div id="nav" class="entrance-el <% if (is_home()) { %> is_home <% } %>">
      <%- partial('_partial/navbar', null, {cache: !config.relative_link}) %>
    </div>
    <div id="sidebar-wrapper" class="entrance-el">
      <%- partial('_partial/sidebar', null, {cache: !config.relative_link}) %>
    </div>
    <div id="content-body" class="entrance-el">
      <main id="swup" class="transition-main">
        <%- body %>
      </main>
    </div>
    <div id="footer-wrapper" class="entrance-el">
      <%- partial('_partial/footer', null, {cache: !config.relative_link}) %>
    </div>
    <%- partial('_partial/back-to-top') %>
  </div>

  <!-- 状态监控 -->
  <script src="<%- url_for("/js/status.js") %>"></script>

  <!-- Swup: 动态丝滑页面切换 -->
  <script src="https://unpkg.com/swup@3"></script>
  <script src="<%- url_for("/js/swup.js") %>"></script>
</body>
</html>
